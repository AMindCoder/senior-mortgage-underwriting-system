# =============================================================================
# Senior Mortgage Underwriting System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# --- OpenAI / LLM Configuration ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- PostgreSQL Database ---
POSTGRES_USER=underwriting
POSTGRES_PASSWORD=underwriting_secret
POSTGRES_DB=mortgage_underwriting
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- ChromaDB Vector Store ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=underwriting_policies

# --- Application Settings ---
APP_HOST=0.0.0.0
APP_PORT=8501
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Policy Document Path ---
POLICY_PDF_PATH=data/underwriting_policies.pdf

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
